{
  "name": "auth-agent",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/api",
    "packages/ui"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=packages/api\" \"npm run dev --workspace=packages/ui\"",
    "dev:api": "npm run dev --workspace=packages/api",
    "dev:ui": "npm run dev --workspace=packages/ui",
    "build": "npm run build --workspace=packages/ui",
    "migrate": "npm run migrate --workspace=packages/api",
    "seed": "npm run seed --workspace=packages/api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^8.2.2"
  }
}
